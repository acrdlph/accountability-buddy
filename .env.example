# Habitify — populated by habitify_oauth_setup.py
HABITIFY_CLIENT_ID=your-client-id-from-oauth-setup
HABITIFY_REFRESH_TOKEN=your-refresh-token-from-oauth-setup

# OpenAI — for Whisper voice note transcription
OPENAI_API_KEY=sk-...

# Hevy — get at https://hevy.com/settings?developer (requires Hevy PRO)
HEVY_API_KEY=your-hevy-api-key

# Strava — create an app at https://www.strava.com/settings/api
# (set "Authorization Callback Domain" to: localhost)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
# STRAVA_ACCESS_TOKEN and STRAVA_REFRESH_TOKEN are populated by
# strava_oauth_setup.py after you authorize the app.
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
